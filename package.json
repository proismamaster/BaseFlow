{
  "name": "baseflow",
  "productName": "BaseFlow",
  "version": "0.2.0",
  "description": "Editor di diagrammi di flusso con esecuzione passo-passo e traduzione in codice",
  "author": {
    "name": "Ismail Barakat",
    "email": "ismailbarakat68@gmail.com",
    "url": "https://ismailbarakat.dev"
  },
  "license": "MIT",
  "homepage": "https://github.com/proismamaster/BaseFlow",
  "repository": {
    "type": "git",
    "url": "https://github.com/proismamaster/BaseFlow.git"
  },
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --inspect",

    "dist": "electron-builder --publish never",
    "dist:win": "electron-builder --win --publish never",
    "dist:mac": "electron-builder --mac --publish never",
    "dist:linux": "electron-builder --linux --publish never",
    "pack": "electron-builder --dir --publish never",

    "android:add": "cap add android",
    "android:sync": "cap sync android",
    "android:open": "cap open android",
    "android:run": "cap run android",

    "icons": "node tools/generate-icons.mjs",
    "vendor:shepherd": "node tools/vendor-shepherd.mjs",
    "test:2026-07-21": "node tools/run-repro-2026-07-21.js"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.2",
    "@capacitor/core": "^8.4.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.2",
    "electron": "^43.1.1",
    "jsdom": "^27.0.0",
    "electron-builder": "^26.15.3",
    "png-to-ico": "^2.1.8",
    "sharp": "^0.34.5",
    "shepherd.js": "^11.2.0"
  }
}
