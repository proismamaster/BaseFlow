# --- Pacchetti nativi (Electron / Capacitor) ---

# Output di electron-builder (installer .exe/.dmg/.AppImage: pesanti, rigenerabili)
/dist/

# Icone derivate: le rigenera "npm run icons" da app/img/icon.png, che e' la sorgente.
# Committarle significa doverle riallineare a mano a ogni ritocco del logo.
/build/icon.ico
/build/icon.icns
/build/icon.png
/build/icons/

# Progetto Android generato da Capacitor ("npm run android:add").
# NB: se un giorno servisse personalizzare i file nativi (permessi nel Manifest,
# splash screen, firma del release), quella cartella va COMMITTATA e questa riga
# rimossa -- altrimenti ogni "cap add" ripristina i default e le modifiche spariscono.
/android/
/ios/

# File binari degli installer pronti per l'upload manuale come asset di una GitHub Release
# (non vanno mai committati: superano il limite di 100MB di GitHub per file su git normale)
/release-assets/
